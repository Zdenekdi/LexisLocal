# LexisLocal — vzor konfigurace prostředí.
# Zkopírujte na `.env` a vyplňte SILNÉ, náhodné hodnoty. Soubor .env je v .gitignore
# a NESMÍ se commitovat. Silný náhodný řetězec vygenerujete např.:
#   openssl rand -base64 32

# Heslo k databázi Paperless (Postgres). Používá se na dvou místech v docker-compose,
# musí být stejné.
PAPERLESS_DB_PASSWORD=zmente-me-na-silne-nahodne-heslo

# Tajný klíč Paperless (Django SECRET_KEY). Náhodný, dlouhý.
PAPERLESS_SECRET_KEY=zmente-me-na-nahodny-dlouhy-klic

# (Volitelné) Token pro LexisLocal API — když je nastaven, vynutí se autentizace
# u backendu na :4000. Stejný token vložte do nastavení editoru i dashboardu.
# API_TOKEN=zmente-me-na-nahodny-token
