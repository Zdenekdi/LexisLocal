{
  "name": "lexis-local",
  "version": "1.1.1",
  "description": "Privacy-focused, local-first AI Legal Ecosystem for Modern Law Firms",
  "main": "electron/main.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "watcher": "node backend/lib/watcher.js",
    "setup": "node setup.js",
    "electron:dev": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win",
    "test": "jest",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "legaltech",
    "local-first",
    "ai-agent",
    "ollama",
    "rag"
  ],
  "author": "Zdeněk Dias",
  "license": "Proprietary",
  "build": {
    "appId": "cz.lexislocal.app",
    "productName": "LexisLocal",
    "copyright": "Copyright © 2025 LexisLocal",
    "asar": true,
    "files": [
      "electron/**/*",
      "backend/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "LexisLocal ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LexisLocal",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "Zdenekdi",
      "repo": "LexisLocal"
    }
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ollama": "^0.5.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.7.284",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "playwright": "^1.60.0",
    "supertest": "^7.2.2"
  }
}
